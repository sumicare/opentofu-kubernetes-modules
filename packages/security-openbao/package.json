{
  "authors": [
    "Yuriy Yarosh <yuriy@yarosh.dev>"
  ],
  "description": "Sumicare OpenBao Chart",
  "devDependencies": {
    "@sumicare/images": "workspace:*",
    "@sumicare/versioning": "workspace:*",
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=25"
  },
  "name": "@sumicare/charts-security-openbao",
  "packageManager": "yarn@4.10.3",
  "private": true,
  "repository": {
    "type": "git",
    "url": ""
  },
  "scripts": {
    "format": "run-p 'format:*'",
    "format:go": "golangci-lint run --fix",
    "format:opentofu": "tofu fmt -recursive .",
    "generate": "versioning sync",
    "lint": "run-p 'lint:*'",
    "lint:go": "golangci-lint run",
    "lint:opentofu": "run-p 'lint:opentofu:*'",
    "lint:opentofu:checkov": "checkov --framework terraform --directory .",
    "lint:opentofu:terrascan": "terrascan scan -t terraform -d .",
    "lint:opentofu:tflint": "run-p 'lint:opentofu:tflint:openbao-chart' 'lint:opentofu:tflint:openbao-image'",
    "lint:opentofu:tflint:openbao-chart": "tflint --chdir modules/openbao-chart",
    "lint:opentofu:tflint:openbao-image": "tflint --chdir modules/openbao-image",
    "lint:opentofu:trivy": "trivy config --severity CRITICAL,HIGH --skip-files '**/*.tpl' .",
    "lint:opentofu:validate": "tofu validate",
    "test": "ginkgo run -v --procs=32 --timeout=60s ./..."
  },
  "type": "module",
  "version": "2.4.4"
}
